#
# Button callback binding verification (helpers in testOllamaChatHelpers.bare)
#
# The render tests above assert each button carries a callback ('<function>'),
# but not WHICH handler or captured arguments it is bound to. These tests pull
# the actual captured callback out of the render and invoke it, proving the
# binding (e.g. that "Up" moves up and not down/delete).
#


async function testOllamaChatIndexConversationActionBinding():
    systemGlobalSet('vAction', 'conversation')
    systemGlobalSet('vActionID', 'C1')
    args = argsParse(ollamaChatArguments)
    conv = {'id': 'C1', 'model': 'm:1', 'title': 'Chat', 'generating': false}
    render = systemPartial(ollamaChatIndexPage, args)
    convData = {'systemFetch': {'getConversations': jsonStringify({'model': 'm:1', 'conversations': [conv], 'templates': []})}}

    # Each action button must be bound to its own action argument
    ollamaChatTestVerifyClick(render, 'Up', systemPartial(ollamaChatIndexOnConversationAction, args, 'C1', 'up'), convData)
    ollamaChatTestVerifyClick(render, 'Down', systemPartial(ollamaChatIndexOnConversationAction, args, 'C1', 'down'), convData)
    ollamaChatTestVerifyClick(render, 'Delete', systemPartial(ollamaChatIndexOnConversationAction, args, 'C1', 'delete'), convData)

    # The menu's Add Template button must be bound to the add-template handler
    ollamaChatTestVerifyClick(render, 'Add Template', ollamaChatIndexOnAddTemplate, \
        {'systemFetch': { \
            'getConversations': jsonStringify({'model': 'm:1', 'conversations': [conv], 'templates': []}), \
            'createTemplate': jsonStringify({'id': 'NEWID'}) \
        }})

    systemGlobalSet('vAction', null)
    systemGlobalSet('vActionID', null)
endfunction
unittestRunTest('testOllamaChatIndexConversationActionBinding')


async function testOllamaChatIndexTemplateActionBinding():
    systemGlobalSet('vAction', 'template')
    systemGlobalSet('vActionID', 'TT')
    args = argsParse(ollamaChatArguments)
    tmpl = {'id': 'TT', 'title': 'Tmpl'}
    render = systemPartial(ollamaChatIndexPage, args)
    tmplData = {'systemFetch': {'getConversations': jsonStringify({'model': 'm:1', 'conversations': [], 'templates': [tmpl]})}}

    # Each action button must be bound to its own action argument
    ollamaChatTestVerifyClick(render, 'Up', systemPartial(ollamaChatIndexOnTemplateAction, args, 'TT', 'up'), tmplData)
    ollamaChatTestVerifyClick(render, 'Down', systemPartial(ollamaChatIndexOnTemplateAction, args, 'TT', 'down'), tmplData)
    ollamaChatTestVerifyClick(render, 'Delete', systemPartial(ollamaChatIndexOnTemplateAction, args, 'TT', 'delete'), tmplData)

    # The template title button must start that template
    ollamaChatTestVerifyClick(render, 'Tmpl', systemPartial(ollamaChatIndexOnRunTemplate, 'TT'), \
        {'systemFetch': { \
            'getConversations': jsonStringify({'model': 'm:1', 'conversations': [], 'templates': [tmpl]}), \
            'getTemplate?id=TT': jsonStringify({'id': 'TT', 'title': 'Tmpl', 'prompts': ['p']}), \
            'startTemplate': jsonStringify({'id': 'CONV'}) \
        }})

    systemGlobalSet('vAction', null)
    systemGlobalSet('vActionID', null)
endfunction
unittestRunTest('testOllamaChatIndexTemplateActionBinding')
