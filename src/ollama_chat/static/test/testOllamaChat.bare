include <unittest.bare>
include <unittestMock.bare>

include '../ollamaChat.bare'
include 'testOllamaChatHelpers.bare'


# The index-page menu controls element-model
testOllamaChatIndexMenuElements = { \
    'html': 'p', \
    'elem': [ \
        formsLinkElements('Select Model', "#var.vView='models'"), \
        {'text': '\u00a0\u00a0|\u00a0\u00a0'}, \
        formsLinkElements('Start Conversation', "#var.vView='chat'"), \
        {'text': '\u00a0\u00a0|\u00a0\u00a0'}, \
        formsLinkButtonElements('Add Template', '<function>') \
    ] \
}


async function testOllamaChatIndex():
    unittestMockAll({ \
        'systemFetch': { \
            'getConversations': jsonStringify({ \
                'model': 'llm:7b', \
                'conversations': [ \
                    {'id': 'ID', 'model': 'llm:7b', 'title': 'Hello', 'generating': false} \
                ] \
            }) \
        } \
    })

    ollamaChatMain()

    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['getConversations']], \
        ['documentSetTitle', ['Ollama Chat']], \
        ['markdownPrint', ['# Ollama Chat']], \
        ['markdownPrint', ['**Current Model:** llm:7b']], \
        ['elementModelRender', [ \
            { \
                'html': 'p', \
                'elem': [ \
                    { \
                        'html': 'a', \
                        'attr': {'href': "#var.vView='models'"}, \
                        'elem': {'text': 'Select Model'} \
                    }, \
                    {'text': '\u00a0\u00a0|\u00a0\u00a0'}, \
                    { \
                        'html': 'a', \
                        'attr': {'href': "#var.vView='chat'"}, \
                        'elem': {'text': 'Start Conversation'} \
                    }, \
                    {'text': '\u00a0\u00a0|\u00a0\u00a0'}, \
                    { \
                        'html': 'a', \
                        'attr': {'style': 'cursor: pointer; user-select: none;'}, \
                        'elem': {'text': 'Add Template'}, \
                        'callback': {'click': '<function>'} \
                    } \
                ] \
            } \
        ]], \
        ['markdownPrint', ['','## Conversations']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'table', \
                    'elem': [ \
                        { \
                            'html': 'tbody', \
                            'elem': [ \
                                { \
                                    'html': 'tr', \
                                    'elem': [ \
                                        { \
                                            'html': 'td', \
                                            'attr': {'style': 'min-width: 10em;'}, \
                                            'elem': { \
                                                'html': 'a', \
                                                'attr': {'href': "#var.vId='ID'&var.vView='chat'"}, \
                                                'elem': {'text': 'Hello'} \
                                            } \
                                        }, \
                                        { \
                                            'html': 'td', \
                                            'elem': {'text': 'llm:7b'} \
                                        }, \
                                        { \
                                            'html': 'td', \
                                            'elem': [ \
                                                { \
                                                    'html': 'a', \
                                                    'attr': {'href': "#var.vAction='conversation'&var.vActionID='ID'"}, \
                                                    'elem': {'text': 'Select'} \
                                                }, \
                                                null \
                                            ] \
                                        } \
                                    ] \
                                } \
                            ] \
                        } \
                    ] \
                } \
            ] \
        ]], \
        ['markdownPrint', ['','## Templates']], \
        ['markdownPrint', ['','\u00a0\u00a0\u00a0\u00a0' + '*No templates*']] \
    ])
endfunction
unittestRunTest('testOllamaChatIndex')


