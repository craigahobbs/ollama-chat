include <unittest.bare>
include <unittestMock.bare>

include '../ollamaChat.bare'
include 'testOllamaChatHelpers.bare'


# Expected element-model for the "Add" button rows (variables / prompts)
testOllamaChatTemplateAddButton = [ \
    { \
        'html': 'p', \
        'elem': formsLinkButtonElements('Add', '<function>') \
    } \
]


# Expected element-model for a formsTextElements text input
function testOllamaChatTemplateInput(id, value):
    return { \
        'html': 'input', \
        'attr': { \
            'autocomplete': 'off', \
            'id': id, \
            'size': 50, \
            'style': 'font-size: inherit; border: thin solid black; padding: 0.4em;', \
            'type': 'text', \
            'value': value \
        }, \
        'callback': {'keyup': '<function>'} \
    }
endfunction


# The Cancel/Update/Remove/Up/Down button row shared by the variable and prompt edit forms
function testOllamaChatTemplateVarPromptButtons():
    return [ \
        formsLinkElements('Cancel', "#var.vId='T1'"), \
        {'text': '\u00a0\u00a0|\u00a0\u00a0'}, \
        formsLinkButtonElements('Update', '<function>'), \
        {'text': '\u00a0\u00a0'}, \
        formsLinkButtonElements('Remove', '<function>'), \
        {'text': '\u00a0\u00a0'}, \
        formsLinkButtonElements('Up', '<function>'), \
        {'text': '\u00a0\u00a0'}, \
        formsLinkButtonElements('Down', '<function>') \
    ]
endfunction


# The title edit link shown when the title is not being edited
function testOllamaChatTemplateTitleEditLink():
    return [['markdownPrint', ['',"[Edit](#var.vAction='title'&var.vId='T1')"]]]
endfunction


# The template name display section
function testOllamaChatTemplateNameDisplay():
    return [ \
        ['markdownPrint', ['','## Template Name']], \
        ['markdownPrint', ['','**Name:** mytmpl','',"[Edit](#var.vAction='name'&var.vId='T1')"]] \
    ]
endfunction


# The variables section header
function testOllamaChatTemplateVarsHeader():
    return [ \
        ['markdownPrint', ['','## Variables','','Variables are used within the template title and prompts like so: `{{variableName}}`']] \
    ]
endfunction


# The variables display section (header + one variable + Add button)
function testOllamaChatTemplateVarsDisplay():
    result = testOllamaChatTemplateVarsHeader()
    arrayExtend(result, [ \
        ['markdownPrint', ['','### Variable #1']], \
        ['markdownPrint', ['','**Name:** v1','','**Label:** L1','',"[Edit](#var.vAction='variable'&var.vActionID='0'&var.vId='T1')"]], \
        ['elementModelRender', [testOllamaChatTemplateAddButton]] \
    ])
    return result
endfunction


# The prompts display section (header + one prompt + Add button)
function testOllamaChatTemplatePromptsDisplay():
    return [ \
        ['markdownPrint', ['','## Prompts']], \
        ['markdownPrint', ['','### Prompt #1']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'p', \
                    'attr': {'style': 'white-space: pre-wrap;'}, \
                    'elem': {'text': 'prompt one'} \
                }, \
                { \
                    'html': 'p', \
                    'elem': [formsLinkElements('Edit', "#var.vAction='prompt'&var.vActionID='0'&var.vId='T1'")] \
                } \
            ] \
        ]], \
        ['elementModelRender', [testOllamaChatTemplateAddButton]] \
    ]
endfunction


#
# ollamaChatTemplatePage - render branches
#


async function testOllamaChatTemplatePageDefault():
    systemGlobalSet('vId', 'T1')
    args = argsParse(ollamaChatArguments)
    tmpl = {'id': 'T1', 'title': 'My Template', 'name': 'mytmpl', 'variables': [{'name': 'v1', 'label': 'L1'}], 'prompts': ['prompt one']}
    unittestMockAll({'systemFetch': {'getTemplate?id=T1': jsonStringify(tmpl)}})
    ollamaChatTemplatePage(args)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['getTemplate?id=T1']], \
        ['documentSetTitle', ['My Template']], \
        ['markdownPrint', ['[Back](#var=)','','# My Template']], \
        ['markdownPrint', ['',"[Edit](#var.vAction='title'&var.vId='T1')"]], \
        ['markdownPrint', ['','## Template Name']], \
        ['markdownPrint', ['','**Name:** mytmpl','',"[Edit](#var.vAction='name'&var.vId='T1')"]], \
        ['markdownPrint', ['','## Variables','','Variables are used within the template title and prompts like so: `{{variableName}}`']], \
        ['markdownPrint', ['','### Variable #1']], \
        ['markdownPrint', ['','**Name:** v1','','**Label:** L1','',"[Edit](#var.vAction='variable'&var.vActionID='0'&var.vId='T1')"]], \
        ['elementModelRender', [testOllamaChatTemplateAddButton]], \
        ['markdownPrint', ['','## Prompts']], \
        ['markdownPrint', ['','### Prompt #1']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'p', \
                    'attr': {'style': 'white-space: pre-wrap;'}, \
                    'elem': {'text': 'prompt one'} \
                }, \
                { \
                    'html': 'p', \
                    'elem': [formsLinkElements('Edit', "#var.vAction='prompt'&var.vActionID='0'&var.vId='T1'")] \
                } \
            ] \
        ]], \
        ['elementModelRender', [testOllamaChatTemplateAddButton]] \
    ])
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatTemplatePageDefault')


async function testOllamaChatTemplatePageEmpty():
    systemGlobalSet('vId', 'T1')
    args = argsParse(ollamaChatArguments)
    tmpl = {'id': 'T1', 'title': 'My Template', 'prompts': []}
    unittestMockAll({'systemFetch': {'getTemplate?id=T1': jsonStringify(tmpl)}})
    ollamaChatTemplatePage(args)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['getTemplate?id=T1']], \
        ['documentSetTitle', ['My Template']], \
        ['markdownPrint', ['[Back](#var=)','','# My Template']], \
        ['markdownPrint', ['',"[Edit](#var.vAction='title'&var.vId='T1')"]], \
        ['markdownPrint', ['','## Template Name']], \
        ['markdownPrint', ['','The template is unnamed','',"[Edit](#var.vAction='name'&var.vId='T1')"]], \
        ['markdownPrint', ['','## Variables','','Variables are used within the template title and prompts like so: `{{variableName}}`']], \
        ['markdownPrint', ['','The template has no variables.']], \
        ['elementModelRender', [testOllamaChatTemplateAddButton]], \
        ['markdownPrint', ['','## Prompts']], \
        ['markdownPrint', ['','The template has no prompts.']], \
        ['elementModelRender', [testOllamaChatTemplateAddButton]] \
    ])
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatTemplatePageEmpty')


async function testOllamaChatTemplatePageTitleEdit():
    systemGlobalSet('vId', 'T1')
    systemGlobalSet('vAction', 'title')
    args = argsParse(ollamaChatArguments)
    tmpl = {'id': 'T1', 'title': 'My Template', 'name': 'mytmpl', 'variables': [{'name': 'v1', 'label': 'L1'}], 'prompts': ['prompt one']}
    unittestMockAll({'systemFetch': {'getTemplate?id=T1': jsonStringify(tmpl)}})
    ollamaChatTemplatePage(args)
    expected = [ \
        ['systemFetch', ['getTemplate?id=T1']], \
        ['documentSetTitle', ['My Template']], \
        ['markdownPrint', ['[Back](#var=)','','# My Template']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'p', \
                    'elem': testOllamaChatTemplateInput('ollama-chat-template-input', 'My Template') \
                }, \
                { \
                    'html': 'p', \
                    'elem': [ \
                        formsLinkElements('Cancel', "#var.vId='T1'"), \
                        {'text': '\u00a0\u00a0|\u00a0\u00a0'}, \
                        formsLinkButtonElements('Update', '<function>') \
                    ] \
                } \
            ] \
        ]], \
        ['documentSetFocus', ['ollama-chat-template-input']] \
    ]
    arrayExtend(expected, testOllamaChatTemplateNameDisplay())
    arrayExtend(expected, testOllamaChatTemplateVarsDisplay())
    arrayExtend(expected, testOllamaChatTemplatePromptsDisplay())
    unittestDeepEqual(unittestMockEnd(), expected)
    systemGlobalSet('vId', null)
    systemGlobalSet('vAction', null)
endfunction
unittestRunTest('testOllamaChatTemplatePageTitleEdit')


async function testOllamaChatTemplatePageNameEdit():
    systemGlobalSet('vId', 'T1')
    systemGlobalSet('vAction', 'name')
    args = argsParse(ollamaChatArguments)
    tmpl = {'id': 'T1', 'title': 'My Template', 'name': 'mytmpl', 'variables': [{'name': 'v1', 'label': 'L1'}], 'prompts': ['prompt one']}
    unittestMockAll({'systemFetch': {'getTemplate?id=T1': jsonStringify(tmpl)}})
    ollamaChatTemplatePage(args)
    expected = [ \
        ['systemFetch', ['getTemplate?id=T1']], \
        ['documentSetTitle', ['My Template']], \
        ['markdownPrint', ['[Back](#var=)','','# My Template']] \
    ]
    arrayExtend(expected, testOllamaChatTemplateTitleEditLink())
    arrayExtend(expected, [ \
        ['markdownPrint', ['','## Template Name']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'p', \
                    'elem': testOllamaChatTemplateInput('ollama-chat-template-input', 'mytmpl') \
                }, \
                { \
                    'html': 'p', \
                    'elem': [ \
                        formsLinkElements('Cancel', "#var.vId='T1'"), \
                        {'text': '\u00a0\u00a0|\u00a0\u00a0'}, \
                        formsLinkButtonElements('Update', '<function>'), \
                        {'text': '\u00a0\u00a0'}, \
                        formsLinkButtonElements('Remove', '<function>') \
                    ] \
                } \
            ] \
        ]], \
        ['documentSetFocus', ['ollama-chat-template-input']] \
    ])
    arrayExtend(expected, testOllamaChatTemplateVarsDisplay())
    arrayExtend(expected, testOllamaChatTemplatePromptsDisplay())
    unittestDeepEqual(unittestMockEnd(), expected)
    systemGlobalSet('vId', null)
    systemGlobalSet('vAction', null)
endfunction
unittestRunTest('testOllamaChatTemplatePageNameEdit')


async function testOllamaChatTemplatePageVariableEdit():
    systemGlobalSet('vId', 'T1')
    systemGlobalSet('vAction', 'variable')
    systemGlobalSet('vActionID', '0')
    args = argsParse(ollamaChatArguments)
    tmpl = {'id': 'T1', 'title': 'My Template', 'name': 'mytmpl', 'variables': [{'name': 'v1', 'label': 'L1'}], 'prompts': ['prompt one']}
    unittestMockAll({'systemFetch': {'getTemplate?id=T1': jsonStringify(tmpl)}})
    ollamaChatTemplatePage(args)
    expected = [ \
        ['systemFetch', ['getTemplate?id=T1']], \
        ['documentSetTitle', ['My Template']], \
        ['markdownPrint', ['[Back](#var=)','','# My Template']] \
    ]
    arrayExtend(expected, testOllamaChatTemplateTitleEditLink())
    arrayExtend(expected, testOllamaChatTemplateNameDisplay())
    arrayExtend(expected, testOllamaChatTemplateVarsHeader())
    arrayExtend(expected, [ \
        ['markdownPrint', ['','### Variable #1']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'p', \
                    'elem': { \
                        'html': 'b', \
                        'elem': {'text': 'Name:'} \
                    } \
                }, \
                { \
                    'html': 'p', \
                    'elem': testOllamaChatTemplateInput('ollama-chat-template-input', 'v1') \
                }, \
                { \
                    'html': 'p', \
                    'elem': { \
                        'html': 'b', \
                        'elem': {'text': 'Label:'} \
                    } \
                }, \
                { \
                    'html': 'p', \
                    'elem': testOllamaChatTemplateInput('ollama-chat-template-input2', 'L1') \
                }, \
                { \
                    'html': 'p', \
                    'elem': testOllamaChatTemplateVarPromptButtons() \
                } \
            ] \
        ]], \
        ['documentSetFocus', ['ollama-chat-template-input']], \
        ['elementModelRender', [testOllamaChatTemplateAddButton]] \
    ])
    arrayExtend(expected, testOllamaChatTemplatePromptsDisplay())
    unittestDeepEqual(unittestMockEnd(), expected)
    systemGlobalSet('vId', null)
    systemGlobalSet('vAction', null)
    systemGlobalSet('vActionID', null)
endfunction
unittestRunTest('testOllamaChatTemplatePageVariableEdit')


async function testOllamaChatTemplatePagePromptEdit():
    systemGlobalSet('vId', 'T1')
    systemGlobalSet('vAction', 'prompt')
    systemGlobalSet('vActionID', '0')
    args = argsParse(ollamaChatArguments)
    tmpl = {'id': 'T1', 'title': 'My Template', 'name': 'mytmpl', 'variables': [{'name': 'v1', 'label': 'L1'}], 'prompts': ['prompt one']}
    unittestMockAll({'systemFetch': {'getTemplate?id=T1': jsonStringify(tmpl)}})
    ollamaChatTemplatePage(args)
    expected = [ \
        ['systemFetch', ['getTemplate?id=T1']], \
        ['documentSetTitle', ['My Template']], \
        ['markdownPrint', ['[Back](#var=)','','# My Template']] \
    ]
    arrayExtend(expected, testOllamaChatTemplateTitleEditLink())
    arrayExtend(expected, testOllamaChatTemplateNameDisplay())
    arrayExtend(expected, testOllamaChatTemplateVarsDisplay())
    arrayExtend(expected, [ \
        ['markdownPrint', ['','## Prompts']], \
        ['markdownPrint', ['','### Prompt #1']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'p', \
                    'elem': { \
                        'html': 'textarea', \
                        'attr': { \
                            'autocomplete': 'off', \
                            'id': 'ollama-chat-template-input', \
                            'rows': 8, \
                            'style': arrayJoin( \
                                [ \
                                    'background-color: var(--barescript-color-background)', \
                                    'color: var(--barescript-color-foreground)', \
                                    'font-size: inherit', \
                                    'font-family: inherit', \
                                    'padding: 0.5em', \
                                    'resize: none', \
                                    'width: calc(100% - 1em)' \
                                ], \
                                '; ' \
                            ) \
                        }, \
                        'elem': {'text': 'prompt one'} \
                    } \
                }, \
                { \
                    'html': 'p', \
                    'elem': testOllamaChatTemplateVarPromptButtons() \
                } \
            ] \
        ]], \
        ['documentSetFocus', ['ollama-chat-template-input']], \
        ['elementModelRender', [testOllamaChatTemplateAddButton]] \
    ])
    unittestDeepEqual(unittestMockEnd(), expected)
    systemGlobalSet('vId', null)
    systemGlobalSet('vAction', null)
    systemGlobalSet('vActionID', null)
endfunction
unittestRunTest('testOllamaChatTemplatePagePromptEdit')


