#
# Button callback binding verification (helpers in testOllamaChatHelpers.bare)
#
# The render tests above assert each button carries a callback ('<function>'),
# but not WHICH handler or captured arguments it is bound to. These tests pull
# the actual captured callback out of the render and invoke it, proving the
# binding (e.g. that a variable's Up moves up, Down moves down, Remove removes).
# ollamaChatTestVerifyClick re-renders fresh per button so the template-mutating
# handlers don't leak state between checks.
#


async function testOllamaChatTemplateTitleButtonBinding():
    systemGlobalSet('vId', 'T1')
    systemGlobalSet('vAction', 'title')
    args = argsParse(ollamaChatArguments)
    tmplJSON = jsonStringify({'id': 'T1', 'title': 'My Title', 'prompts': ['p']})
    render = systemPartial(ollamaChatTemplatePage, args)
    data = {'systemFetch': {'getTemplate?id=T1': tmplJSON}, 'documentInputValue': {'ollama-chat-template-input': 'Updated'}}

    # The title Update button must update this template's title
    ollamaChatTestVerifyClick(render, 'Update', systemPartial(ollamaChatTemplateOnTitle, jsonParse(tmplJSON)), data)

    systemGlobalSet('vId', null)
    systemGlobalSet('vAction', null)
endfunction
unittestRunTest('testOllamaChatTemplateTitleButtonBinding')


async function testOllamaChatTemplateNameButtonBinding():
    systemGlobalSet('vId', 'T1')
    systemGlobalSet('vAction', 'name')
    args = argsParse(ollamaChatArguments)
    tmplJSON = jsonStringify({'id': 'T1', 'title': 'T', 'name': 'oldname', 'prompts': ['p']})
    render = systemPartial(ollamaChatTemplatePage, args)
    data = {'systemFetch': {'getTemplate?id=T1': tmplJSON}, 'documentInputValue': {'ollama-chat-template-input': 'newname'}}

    # Update sets the name; Remove deletes it
    ollamaChatTestVerifyClick(render, 'Update', systemPartial(ollamaChatTemplateOnName, jsonParse(tmplJSON)), data)
    ollamaChatTestVerifyClick(render, 'Remove', systemPartial(ollamaChatTemplateOnNameRemove, jsonParse(tmplJSON)), data)

    systemGlobalSet('vId', null)
    systemGlobalSet('vAction', null)
endfunction
unittestRunTest('testOllamaChatTemplateNameButtonBinding')


async function testOllamaChatTemplateVariableButtonBinding():
    systemGlobalSet('vId', 'T1')
    systemGlobalSet('vAction', 'variable')
    systemGlobalSet('vActionID', '1')
    args = argsParse(ollamaChatArguments)
    tmplJSON = jsonStringify({'id': 'T1', 'title': 'T', 'variables': [ \
        {'name': 'a', 'label': 'A'}, {'name': 'b', 'label': 'B'}, {'name': 'c', 'label': 'C'} \
    ], 'prompts': ['p']})
    render = systemPartial(ollamaChatTemplatePage, args)
    data = {'systemFetch': {'getTemplate?id=T1': tmplJSON}, \
        'documentInputValue': {'ollama-chat-template-input': 'bb', 'ollama-chat-template-input2': 'BB'}}

    # The middle variable's buttons must each bind to their own action at index 1
    ollamaChatTestVerifyClick(render, 'Update', systemPartial(ollamaChatTemplateOnVariableUpdate, jsonParse(tmplJSON), 1), data)
    ollamaChatTestVerifyClick(render, 'Remove', systemPartial(ollamaChatTemplateOnVariableRemove, jsonParse(tmplJSON), 1), data)
    ollamaChatTestVerifyClick(render, 'Up', systemPartial(ollamaChatTemplateOnVariableMove, jsonParse(tmplJSON), 1), data)
    ollamaChatTestVerifyClick(render, 'Down', systemPartial(ollamaChatTemplateOnVariableMove, jsonParse(tmplJSON), 1, true), data)

    systemGlobalSet('vId', null)
    systemGlobalSet('vAction', null)
    systemGlobalSet('vActionID', null)
endfunction
unittestRunTest('testOllamaChatTemplateVariableButtonBinding')


async function testOllamaChatTemplatePromptButtonBinding():
    systemGlobalSet('vId', 'T1')
    systemGlobalSet('vAction', 'prompt')
    systemGlobalSet('vActionID', '1')
    args = argsParse(ollamaChatArguments)
    tmplJSON = jsonStringify({'id': 'T1', 'title': 'T', 'prompts': ['p0', 'p1', 'p2']})
    render = systemPartial(ollamaChatTemplatePage, args)
    data = {'systemFetch': {'getTemplate?id=T1': tmplJSON}, 'documentInputValue': {'ollama-chat-template-input': 'p1new'}}

    # The middle prompt's buttons must each bind to their own action at index 1
    ollamaChatTestVerifyClick(render, 'Update', systemPartial(ollamaChatTemplateOnPromptUpdate, jsonParse(tmplJSON), 1), data)
    ollamaChatTestVerifyClick(render, 'Remove', systemPartial(ollamaChatTemplateOnPromptRemove, jsonParse(tmplJSON), 1), data)
    ollamaChatTestVerifyClick(render, 'Up', systemPartial(ollamaChatTemplateOnPromptMove, jsonParse(tmplJSON), 1), data)
    ollamaChatTestVerifyClick(render, 'Down', systemPartial(ollamaChatTemplateOnPromptMove, jsonParse(tmplJSON), 1, true), data)

    systemGlobalSet('vId', null)
    systemGlobalSet('vAction', null)
    systemGlobalSet('vActionID', null)
endfunction
unittestRunTest('testOllamaChatTemplatePromptButtonBinding')


async function testOllamaChatTemplateAddButtonBinding():
    systemGlobalSet('vId', 'T1')
    args = argsParse(ollamaChatArguments)
    tmplJSON = jsonStringify({'id': 'T1', 'title': 'T', 'variables': [{'name': 'a', 'label': 'A'}], 'prompts': ['p']})
    render = systemPartial(ollamaChatTemplatePage, args)
    data = {'systemFetch': {'getTemplate?id=T1': tmplJSON}}

    # The page renders two "Add" buttons - the first adds a variable, the second a prompt
    ollamaChatTestVerifyClickN(render, 'Add', 0, systemPartial(ollamaChatTemplateOnVariableAdd, jsonParse(tmplJSON)), data)
    ollamaChatTestVerifyClickN(render, 'Add', 1, systemPartial(ollamaChatTemplateOnPromptAdd, jsonParse(tmplJSON)), data)

    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatTemplateAddButtonBinding')


async function testOllamaChatTemplateVariablesPageBinding():
    systemGlobalSet('vId', 'T1')
    args = argsParse(ollamaChatArguments)
    tmplJSON = jsonStringify({'id': 'T1', 'title': 'T', 'variables': [{'name': 'a', 'label': 'A'}], 'prompts': ['p']})
    render = systemPartial(ollamaChatTemplateVariablesPage, args)
    data = {'systemFetch': {'getTemplate?id=T1': tmplJSON, 'startTemplate': jsonStringify({'id': 'CONV'})}, \
        'documentInputValue': {'variable-a': 'val'}}

    # The Start Conversation button must submit this template's variables
    ollamaChatTestVerifyClick(render, 'Start Conversation', \
        systemPartial(ollamaChatTemplateVariablesOnSubmit, 'T1', objectGet(jsonParse(tmplJSON), 'variables')), data)

    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatTemplateVariablesPageBinding')
