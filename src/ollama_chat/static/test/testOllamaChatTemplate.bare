async function testOllamaChatTemplateVariablesPage():
    systemGlobalSet('vId', 'T1')
    args = argsParse(ollamaChatArguments)
    tmpl = {'id': 'T1', 'title': 'My Template', 'variables': [{'name': 'v1', 'label': 'L1'}, {'name': 'v2', 'label': 'L2'}]}
    unittestMockAll({'systemFetch': {'getTemplate?id=T1': jsonStringify(tmpl)}})
    ollamaChatTemplateVariablesPage(args)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['getTemplate?id=T1']], \
        ['documentSetTitle', ['Variables - My Template']], \
        ['markdownPrint', ['[Back](#var=)','','# Variables \- My Template']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'p', \
                    'elem': { \
                        'html': 'b', \
                        'elem': {'text': 'L1'} \
                    } \
                }, \
                { \
                    'html': 'p', \
                    'elem': { \
                        'html': 'input', \
                        'attr': { \
                            'autocomplete': 'off', \
                            'id': 'variable-v1', \
                            'size': 50, \
                            'style': 'font-size: inherit; border: thin solid black; padding: 0.4em;', \
                            'type': 'text', \
                            'value': '' \
                        }, \
                        'callback': null \
                    } \
                } \
            ] \
        ]], \
        ['documentSetFocus', ['variable-v1']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'p', \
                    'elem': { \
                        'html': 'b', \
                        'elem': {'text': 'L2'} \
                    } \
                }, \
                { \
                    'html': 'p', \
                    'elem': { \
                        'html': 'input', \
                        'attr': { \
                            'autocomplete': 'off', \
                            'id': 'variable-v2', \
                            'size': 50, \
                            'style': 'font-size: inherit; border: thin solid black; padding: 0.4em;', \
                            'type': 'text', \
                            'value': '' \
                        }, \
                        'callback': {'keyup': '<function>'} \
                    } \
                } \
            ] \
        ]], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'p', \
                    'elem': formsLinkButtonElements('Start Conversation', '<function>') \
                } \
            ] \
        ]] \
    ])
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatTemplateVariablesPage')


#
# ollamaChatTemplateOnTitle
#


async function testOllamaChatTemplateOnTitleNonEmpty():
    unittestMockAll({'documentInputValue': {'ollama-chat-template-input': 'New Title'}})
    ollamaChatTemplateOnTitle({'id': 'T1', 'title': 'Old', 'prompts': ['p0']})
    unittestDeepEqual(unittestMockEnd(), [ \
        ['documentInputValue', ['ollama-chat-template-input']], \
        ['systemFetch', [ \
            { \
                'url': 'updateTemplate', \
                'body': '{"id":"T1","prompts":["p0"],"title":"New Title"}' \
            } \
        ]], \
        ['windowSetLocation', ['#var=']] \
    ])
endfunction
unittestRunTest('testOllamaChatTemplateOnTitleNonEmpty')


async function testOllamaChatTemplateOnTitleEmpty():
    unittestMockAll({'documentInputValue': {'ollama-chat-template-input': '  '}})
    ollamaChatTemplateOnTitle({'id': 'T1', 'title': 'Old', 'prompts': ['p0']})
    unittestDeepEqual(unittestMockEnd(), [['documentInputValue', ['ollama-chat-template-input']], ['windowSetLocation', ['#var=']]])
endfunction
unittestRunTest('testOllamaChatTemplateOnTitleEmpty')


