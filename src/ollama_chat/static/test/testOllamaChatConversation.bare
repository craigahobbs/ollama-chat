#
# Button callback binding verification (helpers in testOllamaChatHelpers.bare)
#
# The render tests above assert each control carries a callback ('<function>'),
# but not WHICH handler or captured arguments it is bound to. These tests pull
# the actual captured callback out of the model and invoke it, proving the
# binding (e.g. that the Title button navigates to the title URL and the send
# button submits the prompt). The Download control is a plain <a href>, so its
# binding is already covered by the structural render assertions above.
#


async function testOllamaChatConversationMenuButtonBinding():
    systemGlobalSet('vMenu', true)
    systemGlobalSet('vId', 'C1')
    conv = {'id': 'C1', 'title': 'Conversation Number 1', 'model': 'm:1', 'exchanges': [{'user': 'u', 'model': 'r'}]}
    args = argsParse(ollamaChatArguments)

    # Capture the live menu-control callbacks (menu expanded, not generating)
    unittestMockAll({})
    els = ollamaChatConversationFloatingElements(args, conv, false)
    unittestMockEnd()

    # The navigation buttons must each call OnClick with their own toggle URL
    navData = {'documentInputValue': {'ollama-chat-prompt': ''}}
    ollamaChatTestSameEffect( \
        ollamaChatTestFindClick(els, '<<'), \
        systemPartial(ollamaChatConversationOnClick, args, null, argsURL(ollamaChatArguments, {'menu': false})), \
        navData \
    )
    ollamaChatTestSameEffect( \
        ollamaChatTestFindClick(els, 'Title'), \
        systemPartial(ollamaChatConversationOnClick, args, null, argsURL(ollamaChatArguments, {'action': 'title'})), \
        navData \
    )
    ollamaChatTestSameEffect( \
        ollamaChatTestFindClick(els, 'Text'), \
        systemPartial(ollamaChatConversationOnClick, args, null, argsURL(ollamaChatArguments, {'text': true})), \
        navData \
    )

    # The Delete button must call the deleteConversation API then navigate to the index
    ollamaChatTestSameEffect( \
        ollamaChatTestFindClick(els, 'Delete'), \
        systemPartial(ollamaChatConversationOnClick, args, 'deleteConversation', argsURL(ollamaChatArguments, null, true), true), \
        {} \
    )

    # The Template button must build a template from this conversation
    ollamaChatTestSameEffect( \
        ollamaChatTestFindClick(els, 'Template'), \
        systemPartial(ollamaChatConversationOnTemplate, conv), \
        {'systemFetch': {'createTemplate': jsonStringify({'id': 'TID'})}} \
    )

    systemGlobalSet('vMenu', null)
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatConversationMenuButtonBinding')


async function testOllamaChatConversationPromptButtonBinding():
    args = argsParse(ollamaChatArguments)

    # Capture the live prompt-control callbacks for a new (no-conversation) chat
    unittestMockAll({})
    els = ollamaChatConversationFloatingElements(args, null, false)
    unittestMockEnd()
    promptElem = objectGet(arrayGet(els, 2), 'elem')
    multilineFn = objectGet(objectGet(arrayGet(promptElem, 0), 'callback'), 'click')
    keyupFn = objectGet(objectGet(arrayGet(promptElem, 1), 'callback'), 'keyup')
    sendFn = objectGet(objectGet(arrayGet(promptElem, 2), 'callback'), 'click')

    # The hamburger button toggles multiline mode
    ollamaChatTestSameEffect( \
        multilineFn, \
        systemPartial(ollamaChatConversationOnClick, args, null, argsURL(ollamaChatArguments, {'multiline': true})), \
        {'documentInputValue': {'ollama-chat-prompt': ''}} \
    )

    # The send button and the prompt's Enter key both submit the prompt
    startData = {'systemFetch': {'startConversation': jsonStringify({'id': 'CONV'})}, \
        'documentInputValue': {'ollama-chat-prompt': 'Hello'}}
    ollamaChatTestSameEffect(sendFn, systemPartial(ollamaChatConversationOnPrompt, args), startData)
    ollamaChatTestSameEffect( \
        systemPartial(keyupFn, 13), \
        systemPartial(ollamaChatConversationOnPrompt, args), \
        startData \
    )
endfunction
unittestRunTest('testOllamaChatConversationPromptButtonBinding')


async function testOllamaChatConversationStopButtonBinding():
    systemGlobalSet('vId', 'C1')
    conv = {'id': 'C1', 'title': 'Chat', 'model': 'm:1', 'exchanges': [{'user': 'u', 'model': 'r'}]}
    args = argsParse(ollamaChatArguments)

    # Capture the live stop-button callback (generating -> stop replaces send)
    unittestMockAll({})
    els = ollamaChatConversationFloatingElements(args, conv, true)
    unittestMockEnd()
    stopFn = objectGet(objectGet(arrayGet(objectGet(arrayGet(els, 2), 'elem'), 3), 'callback'), 'click')

    # The stop button must call the stopConversation API then re-render in place
    ollamaChatTestSameEffect( \
        stopFn, \
        systemPartial(ollamaChatConversationOnClick, args, 'stopConversation', null, false), \
        {'systemFetch': objectNew('getConversation?id=C1', jsonStringify({'conversation': conv})), \
            'documentInputValue': {'ollama-chat-prompt': ''}} \
    )

    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatConversationStopButtonBinding')


async function testOllamaChatConversationPageBottomButtonBinding():
    systemGlobalSet('vId', 'C1')
    args = argsParse(ollamaChatArguments)
    conv = {'conversation': {'id': 'C1', 'title': 'Chat', 'model': 'm:1', 'generating': false, \
        'exchanges': [{'user': 'u1', 'model': 'r1'}]}}
    render = systemPartial(ollamaChatConversationPage, args)
    data = {'systemFetch': objectNew('getConversation?id=C1', jsonStringify(conv)), \
        'documentInputValue': {'ollama-chat-prompt': ''}}

    # The page-bottom exchange buttons must each call OnClick with their own API
    ollamaChatTestVerifyClick(render, 'Delete', \
        systemPartial(ollamaChatConversationOnClick, args, 'deleteConversationExchange'), data)
    ollamaChatTestVerifyClick(render, 'Regenerate', \
        systemPartial(ollamaChatConversationOnClick, args, 'regenerateConversationExchange'), data)

    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatConversationPageBottomButtonBinding')


async function testOllamaChatConversationTitleEditButtonBinding():
    systemGlobalSet('vId', 'C1')
    systemGlobalSet('vAction', 'title')
    args = argsParse(ollamaChatArguments)
    conv = {'conversation': {'id': 'C1', 'title': 'Chat', 'model': 'm:1', 'generating': false, \
        'exchanges': [{'user': 'u1', 'model': 'r1'}]}}
    render = systemPartial(ollamaChatConversationPage, args)
    data = {'systemFetch': objectNew('getConversation?id=C1', jsonStringify(conv)), \
        'documentInputValue': {'ollama-chat-title': 'New', 'ollama-chat-prompt': ''}}

    # The Update button saves the title; Cancel navigates back without saving
    ollamaChatTestVerifyClick(render, 'Update', systemPartial(ollamaChatConversationOnTitleUpdate, args), data)
    ollamaChatTestVerifyClick(render, 'Cancel', \
        systemPartial(ollamaChatConversationOnClick, args, null, argsURL(ollamaChatArguments)), data)

    systemGlobalSet('vId', null)
    systemGlobalSet('vAction', null)
endfunction
unittestRunTest('testOllamaChatConversationTitleEditButtonBinding')
