function testOllamaChatConversationFloatingMenuOpen():
    systemGlobalSet('vMenu', true)
    systemGlobalSet('vId', 'C1')
    # The title is long enough that the markdown's first 20 chars (used by the windowURLObject
    # download href) contain no "*", which urlEncode encodes differently across bare runtimes.
    conv = {'id': 'C1', 'title': 'Conversation Number 1', 'model': 'm:1', 'exchanges': [{'user': 'u', 'model': 'r'}]}
    args = argsParse(ollamaChatArguments)
    unittestMockAll({})
    els = ollamaChatConversationFloatingElements(args, conv, false)
    unittestMockEnd()
    downloadLink = {'html': 'a', 'attr': { \
        'href': 'blob:text/markdown-#%20Conversation%20Numbe', 'download': 'conversation-number-1.md' \
    }, 'elem': {'text': 'Download'}}
    unittestDeepEqual(els, [ \
        testOllamaChatConversationTopSpace, \
        testOllamaChatConversationMenuDiv( \
            "#var.vId='C1'&var.vMenu=true&_top", \
            "#var.vId='C1'&var.vMenu=true&chat-bottom", \
            [ \
                {'text': '\u00a0|\u00a0'}, \
                formsLinkButtonElements('<<', '<function>'), \
                [ \
                    {'text': '\u00a0|\u00a0'}, \
                    formsLinkButtonElements('Title', '<function>'), \
                    {'text': '\u00a0|\u00a0'}, \
                    formsLinkButtonElements('Text', '<function>'), \
                    {'text': '\u00a0|\u00a0'}, \
                    downloadLink, \
                    {'text': '\u00a0|\u00a0'}, \
                    formsLinkButtonElements('Template', '<function>'), \
                    {'text': '\u00a0|\u00a0'}, \
                    formsLinkButtonElements('Delete', '<function>') \
                ] \
            ] \
        ), \
        { \
            'html': 'div', \
            'attr': {'style': testOllamaChatConversationPromptDivStyle(false)}, \
            'elem': [ \
                testOllamaChatConversationHamburger(), \
                testOllamaChatConversationPromptInput(null, {'keyup': '<function>'}), \
                testOllamaChatConversationSendButton(), \
                null \
            ] \
        } \
    ])
    systemGlobalSet('vMenu', null)
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatConversationFloatingMenuOpen')


