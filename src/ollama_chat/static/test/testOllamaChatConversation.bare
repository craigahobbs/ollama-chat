#
# ollamaChatConversationOnClick / OnPrompt - page re-render paths
#


async function testOllamaChatConversationOnClickRerender():
    # No navigation URL -> call the API then re-render the page in place
    systemGlobalSet('vId', 'C1')
    args = argsParse(ollamaChatArguments)
    conv = {'conversation': {'id': 'C1', 'title': 'Chat', 'model': 'm:1', 'generating': false, \
        'exchanges': [{'user': 'u1', 'model': 'r1'}]}}
    unittestMockAll({'systemFetch': objectNew('getConversation?id=C1', jsonStringify(conv)), \
        'documentInputValue': {'ollama-chat-prompt': ''}})
    ollamaChatConversationOnClick(args, 'deleteConversationExchange', null, null)
    expected = [ \
        ['systemFetch', [ \
            { \
                'url': 'deleteConversationExchange', \
                'body': '{"id":"C1"}' \
            } \
        ]], \
        ['documentInputValue', ['ollama-chat-prompt']] \
    ]
    arrayExtend(expected, testOllamaChatConversationPage1ExchangeCalls())
    unittestDeepEqual(unittestMockEnd(), expected)
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatConversationOnClickRerender')


async function testOllamaChatConversationOnPromptReply():
    # Existing conversation -> reply, re-render the page, scroll to bottom
    systemGlobalSet('vId', 'C1')
    args = argsParse(ollamaChatArguments)
    conv = {'conversation': {'id': 'C1', 'title': 'Chat', 'model': 'm:1', 'generating': false, \
        'exchanges': [{'user': 'u1', 'model': 'r1'}]}}
    unittestMockAll({'systemFetch': objectNew('getConversation?id=C1', jsonStringify(conv))})
    ollamaChatConversationOnPrompt(args, 'hello')
    expected = [ \
        ['systemFetch', [ \
            { \
                'url': 'replyConversation', \
                'body': '{"id":"C1","user":"hello"}' \
            } \
        ]] \
    ]
    arrayExtend(expected, testOllamaChatConversationPage1ExchangeCalls())
    arrayExtend(expected, [['windowSetLocation', ["#var.vId='C1'&chat-bottom"]]])
    unittestDeepEqual(unittestMockEnd(), expected)
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatConversationOnPromptReply')


