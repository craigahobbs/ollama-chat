async function testOllamaChatConversationOnTimeoutError():
    systemGlobalSet('vId', 'C1')
    args = argsParse(ollamaChatArguments)
    unittestMockAll({})
    ollamaChatConversationOnTimeout(args, 1, false)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['getConversation?id=C1']], \
        ['documentSetTitle', ['Ollama Chat']], \
        ['markdownPrint', ['[Back](#var=)','','# Ollama Chat','','**ERROR:** Unknown conversation ID']] \
    ])
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatConversationOnTimeoutError')


async function testOllamaChatConversationOnTimeoutDone():
    # Generation finished -> save the prompt and re-render the full page
    systemGlobalSet('vId', 'C1')
    args = argsParse(ollamaChatArguments)
    conv = {'conversation': {'id': 'C1', 'title': 'Chat', 'model': 'm:1', 'generating': false, \
        'exchanges': [{'user': 'u1', 'model': 'r1'}]}}
    unittestMockAll({'systemFetch': objectNew('getConversation?id=C1', jsonStringify(conv)), \
        'documentInputValue': {'ollama-chat-prompt': ''}})
    ollamaChatConversationOnTimeout(args, 1, false)
    expected = [['systemFetch', ['getConversation?id=C1']], ['documentInputValue', ['ollama-chat-prompt']]]
    arrayExtend(expected, testOllamaChatConversationPage1ExchangeCalls())
    unittestDeepEqual(unittestMockEnd(), expected)
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatConversationOnTimeoutDone')


async function testOllamaChatConversationOnTimeoutChanged():
    # Still generating but the exchange count changed -> full re-render
    systemGlobalSet('vId', 'C1')
    args = argsParse(ollamaChatArguments)
    conv = {'conversation': {'id': 'C1', 'title': 'Chat', 'model': 'm:1', 'generating': true, \
        'exchanges': [{'user': 'u1', 'model': 'r1'}]}}
    unittestMockAll({'systemFetch': objectNew('getConversation?id=C1', jsonStringify(conv))})
    ollamaChatConversationOnTimeout(args, 0, false)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['getConversation?id=C1']], \
        ['systemFetch', ['getConversation?id=C1']], \
        ['elementModelRender', [testOllamaChatConversationFloatingConvGenerating()]], \
        ['documentSetFocus', ['ollama-chat-prompt']], \
        ['documentSetTitle', ['Chat']], \
        ['markdownPrint', ['# Chat','','**Model:** m:1']], \
        ['elementModelRender', [testOllamaChatConversationMessage(0, null, 'chat-bottom', 'u1')]], \
        ['elementModelRender', [testOllamaChatConversationResetDiv]], \
        ['markdownPrint', ['','r1']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'div', \
                    'attr': {'style': 'height: 512.000px'} \
                }, \
                { \
                    'html': 'div', \
                    'attr': {'id': "var.vId='C1'&chat-bottom"} \
                } \
            ] \
        ]], \
        ['windowSetTimeout', ['<function>',500]] \
    ])
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatConversationOnTimeoutChanged')


