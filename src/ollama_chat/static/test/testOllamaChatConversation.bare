function testOllamaChatConversationSVGButtonStroke():
    # symbolFill = false (stroked symbol), backgroundFill = false (no circle)
    unittestDeepEqual( \
        ollamaChatConversationSVGButton(24, 32, 24, 'M4,6 H20', false, false, ollamaChatModelsModelURL), \
        { \
            'html': 'button', \
            'attr': { \
                'type': 'button', \
                'style': 'background: transparent; border: none; padding: 0; cursor: pointer', \
                'onmouseover': "this.children[0].style.opacity='0.6';", \
                'onmouseout': "this.children[0].style.opacity='1';" \
            }, \
            'elem': { \
                'svg': 'svg', \
                'attr': { \
                    'width': '24.000', \
                    'height': '32.000', \
                    'viewBox': '0 0 24 24', \
                    'fill': 'none', \
                    'style': 'vertical-align: middle', \
                    'preserveAspectRatio': 'none' \
                }, \
                'elem': [ \
                    null, \
                    { \
                        'svg': 'path', \
                        'attr': { \
                            'd': 'M4,6 H20', \
                            'style': 'fill: none; stroke: var(--barescript-color-foreground); stroke-width: 2.40' \
                        } \
                    } \
                ] \
            }, \
            'callback': {'click': '<function>'} \
        } \
    )
endfunction
