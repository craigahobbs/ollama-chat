async function testOllamaChatConversationPageNewConv():
    args = argsParse(ollamaChatArguments)
    unittestMockAll({})
    ollamaChatConversationPage(args)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['elementModelRender', [testOllamaChatConversationFloatingNoConv()]], \
        ['documentSetFocus', ['ollama-chat-prompt']], \
        ['documentSetTitle', ['Ollama Chat']] \
    ])
endfunction
unittestRunTest('testOllamaChatConversationPageNewConv')


async function testOllamaChatConversationPageWithExchanges():
    systemGlobalSet('vId', 'C1')
    args = argsParse(ollamaChatArguments)
    conv = {'conversation': {'id': 'C1', 'title': 'Chat', 'model': 'm:1', 'generating': false, 'exchanges': [ \
        {'user': 'u1', 'model': 'r1'}, {'user': 'u2', 'model': 'r2'}, {'user': 'u3', 'model': 'r3'} \
    ]}}
    unittestMockAll({'systemFetch': objectNew('getConversation?id=C1', jsonStringify(conv))})
    ollamaChatConversationPage(args)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['getConversation?id=C1']], \
        ['elementModelRender', [testOllamaChatConversationFloatingConv()]], \
        ['documentSetFocus', ['ollama-chat-prompt']], \
        ['documentSetTitle', ['Chat']], \
        ['markdownPrint', ['# Chat','','**Model:** m:1']], \
        ['elementModelRender', [testOllamaChatConversationMessage(0, null, 'chat-message-1', 'u1')]], \
        ['markdownPrint', ['','r1']], \
        ['elementModelRender', [testOllamaChatConversationMessage(1, 0, 'chat-message-2', 'u2')]], \
        ['markdownPrint', ['','r2']], \
        ['elementModelRender', [testOllamaChatConversationMessage(2, 1, 'chat-bottom', 'u3')]], \
        ['elementModelRender', [testOllamaChatConversationResetDiv]], \
        ['markdownPrint', ['','r3']], \
        ['elementModelRender', [testOllamaChatConversationBottomMenu(2)]], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'div', \
                    'attr': {'style': 'height: 64.000px'} \
                }, \
                { \
                    'html': 'div', \
                    'attr': {'id': "var.vId='C1'&chat-bottom"} \
                } \
            ] \
        ]] \
    ])
    systemGlobalSet('vId', null)
endfunction
unittestRunTest('testOllamaChatConversationPageWithExchanges')


async function testOllamaChatConversationPageTitleEdit():
    systemGlobalSet('vId', 'C1')
    systemGlobalSet('vAction', 'title')
    args = argsParse(ollamaChatArguments)
    conv = {'conversation': {'id': 'C1', 'title': 'Chat', 'model': 'm:1', 'generating': false, \
        'exchanges': [{'user': 'u1', 'model': 'r1'}]}}
    unittestMockAll({'systemFetch': objectNew('getConversation?id=C1', jsonStringify(conv))})
    ollamaChatConversationPage(args)
    expected = [ \
        ['systemFetch', ['getConversation?id=C1']], \
        ['elementModelRender', [testOllamaChatConversationFloatingConv()]], \
        ['documentSetFocus', ['ollama-chat-prompt']], \
        ['documentSetTitle', ['Chat']], \
        ['markdownPrint', ['','**Title:**']], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'p', \
                    'elem': { \
                        'html': 'input', \
                        'attr': { \
                            'autocomplete': 'off', \
                            'id': 'ollama-chat-title', \
                            'size': 50, \
                            'style': 'font-size: inherit; border: thin solid black; padding: 0.4em;', \
                            'type': 'text', \
                            'value': 'Chat' \
                        }, \
                        'callback': {'keyup': '<function>'} \
                    } \
                }, \
                { \
                    'html': 'p', \
                    'elem': [ \
                        formsLinkButtonElements('Update', '<function>'), \
                        {'text': '\u00a0\u00a0'}, \
                        formsLinkButtonElements('Cancel', '<function>') \
                    ] \
                } \
            ] \
        ]], \
        ['documentSetFocus', ['ollama-chat-title']], \
        ['elementModelRender', [testOllamaChatConversationMessage(0, null, 'chat-bottom', 'u1')]], \
        ['elementModelRender', [testOllamaChatConversationResetDiv]], \
        ['markdownPrint', ['','r1']], \
        ['elementModelRender', [testOllamaChatConversationBottomMenu(0)]], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'div', \
                    'attr': {'style': 'height: 64.000px'} \
                }, \
                { \
                    'html': 'div', \
                    'attr': {'id': "var.vId='C1'&chat-bottom"} \
                } \
            ] \
        ]] \
    ]
    unittestDeepEqual(unittestMockEnd(), expected)
    systemGlobalSet('vId', null)
    systemGlobalSet('vAction', null)
endfunction
unittestRunTest('testOllamaChatConversationPageTitleEdit')


