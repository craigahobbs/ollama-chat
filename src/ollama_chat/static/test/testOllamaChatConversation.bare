include <unittest.bare>
include <unittestMock.bare>

include '../ollamaChat.bare'
include 'testOllamaChatHelpers.bare'


# Computed-style fixtures for the floating controls (documentFontSize mock = 16, windowHeight mock = 768)
testOllamaChatConversationTopSpace = { \
    'html': 'div', \
    'attr': {'style': 'height: 32.000px'} \
}
testOllamaChatConversationMenuStyle = arrayJoin([ \
    'align-items: left', \
    'background-color: var(--barescript-color-background-code)', \
    'border-radius: 8.000px', \
    'color: var(--barescript-color-foreground)', \
    'display: flex', \
    'left: 16.000px', \
    'padding: 10.400px', \
    'position: fixed', \
    'top: 16.000px' \
], '; ')
testOllamaChatConversationInputStyle = arrayJoin([ \
    'background-color: var(--barescript-color-background)', \
    'color: var(--barescript-color-foreground)', \
    'border: none', \
    'flex: 1', \
    'font-size: inherit', \
    'font-family: inherit', \
    'margin-left: 8.000px', \
    'margin-right: 8.000px', \
    'min-width: 0', \
    'outline: none', \
    'padding: 8.000px', \
    'resize: none' \
], '; ')


# The prompt-row div style (align-items differs for multiline)
function testOllamaChatConversationPromptDivStyle(multiline):
    return arrayJoin([ \
        'align-items: ' + if(multiline, 'flex-end', 'center'), \
        'background-color: var(--barescript-color-border)', \
        'border-radius: 8.000px', \
        'bottom: 16.000px', \
        'display: flex', \
        'left: 32.000px', \
        'padding: 12.000px', \
        'position: fixed', \
        'right: 32.000px' \
    ], '; ')
endfunction


# Expected SVG buttons (built from the separately-tested builder; dummy callback -> '<function>')
function testOllamaChatConversationHamburger():
    return ollamaChatConversationSVGButton(24, 32, 24, 'M4,6 H20 M4,12 H20 M4,18 H20', false, false, '<function>')
endfunction
function testOllamaChatConversationSendButton():
    return ollamaChatConversationSVGButton(32, 32, 24, 'M12,18 V7 M7,12 L12,7 L17,12', false, true, '<function>')
endfunction
function testOllamaChatConversationStopButton():
    return ollamaChatConversationSVGButton(32, 32, 24, 'M8,8 H16 V16 H8 Z', true, true, '<function>')
endfunction


# Expected single-line prompt input element (callback is {'keyup': '<function>'} or null while generating)
function testOllamaChatConversationPromptInput(value, callback):
    return { \
        'html': 'input', \
        'attr': { \
            'autocomplete': 'off', \
            'id': 'ollama-chat-prompt', \
            'placeholder': 'Type your message...', \
            'rows': null, \
            'style': testOllamaChatConversationInputStyle, \
            'type': 'text', \
            'value': value \
        }, \
        'callback': callback, \
        'elem': null \
    }
endfunction


# Expected multiline prompt textarea element
function testOllamaChatConversationTextarea():
    return { \
        'html': 'textarea', \
        'attr': { \
            'autocomplete': 'off', \
            'id': 'ollama-chat-prompt', \
            'placeholder': 'Type your message...', \
            'rows': 8, \
            'style': testOllamaChatConversationInputStyle, \
            'type': null, \
            'value': null \
        }, \
        'callback': null, \
        'elem': null \
    }
endfunction


# Expected menu div (Back / Top / Bottom plus an optional conversation-controls part)
function testOllamaChatConversationMenuDiv(topHref, bottomHref, convPart):
    return { \
        'html': 'div', \
        'attr': {'style': testOllamaChatConversationMenuStyle}, \
        'elem': [ \
            formsLinkElements('Back', '#var='), \
            {'text': '\u00a0|\u00a0'}, \
            formsLinkElements('Top', topHref), \
            {'text': '\u00a0|\u00a0'}, \
            formsLinkElements('Bottom', bottomHref), \
            convPart \
        ] \
    }
endfunction


# The full floating-controls model for a new (no-conversation) chat
function testOllamaChatConversationFloatingNoConv():
    return [ \
        testOllamaChatConversationTopSpace, \
        testOllamaChatConversationMenuDiv('#var=&_top', '#var=&chat-bottom', null), \
        { \
            'html': 'div', \
            'attr': {'style': testOllamaChatConversationPromptDivStyle(false)}, \
            'elem': [ \
                testOllamaChatConversationHamburger(), \
                testOllamaChatConversationPromptInput(null, {'keyup': '<function>'}), \
                testOllamaChatConversationSendButton(), \
                null \
            ] \
        } \
    ]
endfunction


# The full floating-controls model for a conversation (not generating, menu collapsed)
function testOllamaChatConversationFloatingConv():
    return [ \
        testOllamaChatConversationTopSpace, \
        testOllamaChatConversationMenuDiv( \
            "#var.vId='C1'&_top", \
            "#var.vId='C1'&chat-bottom", \
            [{'text': '\u00a0|\u00a0'}, formsLinkButtonElements('>>', '<function>'), null] \
        ), \
        { \
            'html': 'div', \
            'attr': {'style': testOllamaChatConversationPromptDivStyle(false)}, \
            'elem': [ \
                testOllamaChatConversationHamburger(), \
                testOllamaChatConversationPromptInput(null, {'keyup': '<function>'}), \
                testOllamaChatConversationSendButton(), \
                null \
            ] \
        } \
    ]
endfunction


# Expected previous/next navigation <p> below a User heading (nextAnchor = the Next link's anchor suffix)
function testOllamaChatConversationMessageNavElements(prevIx, nextAnchor):
    links = []
    if prevIx != null:
        arrayPush(links, formsLinkElements('Previous', "#var.vId='C1'&chat-message-" + prevIx))
        arrayPush(links, {'text': '\u00a0|\u00a0'})
    endif
    arrayPush(links, formsLinkElements('Next', "#var.vId='C1'&" + nextAnchor))
    return {'html': 'p', 'elem': links}
endfunction


# Expected per-exchange element model: anchor + User heading + nav + user message + Model heading
function testOllamaChatConversationMessage(ixMessage, prevIx, nextAnchor, user):
    return [ \
        {'html': 'div', 'attr': {'id': "var.vId='C1'&chat-message-" + ixMessage}}, \
        {'html': 'h2', 'elem': {'text': 'User:'}}, \
        testOllamaChatConversationMessageNavElements(prevIx, nextAnchor), \
        {'html': 'p', 'attr': {'style': 'white-space: pre-wrap;'}, 'elem': {'text': user}}, \
        {'html': 'h2', 'elem': {'text': 'Model:'}} \
    ]
endfunction


# Expected bottom menu <p> (Previous to the top of the last message ixLast, plus Delete and Regenerate)
function testOllamaChatConversationBottomMenu(ixLast):
    return {'html': 'p', 'elem': [ \
        formsLinkElements('Previous', "#var.vId='C1'&chat-message-" + ixLast), \
        {'text': '\u00a0|\u00a0'}, \
        formsLinkButtonElements('Delete', '<function>'), \
        {'text': '\u00a0|\u00a0'}, \
        formsLinkButtonElements('Regenerate', '<function>') \
    ]}
endfunction


# The full floating-controls model for a generating conversation (stop button, no menu controls)
function testOllamaChatConversationFloatingConvGenerating():
    return [ \
        testOllamaChatConversationTopSpace, \
        testOllamaChatConversationMenuDiv("#var.vId='C1'&_top", "#var.vId='C1'&chat-bottom", null), \
        { \
            'html': 'div', \
            'attr': {'style': testOllamaChatConversationPromptDivStyle(false)}, \
            'elem': [ \
                testOllamaChatConversationHamburger(), \
                testOllamaChatConversationPromptInput(null, null), \
                null, \
                testOllamaChatConversationStopButton() \
            ] \
        } \
    ]
endfunction


# The reset-anchor div (an empty div is invisible; documentSetReset only needs the element id present)
testOllamaChatConversationResetDiv = { \
    'html': 'div', \
    'attr': {'id': 'ollama-chat-document-reset-id'} \
}


# The call-log entries for a full single-exchange (not generating) conversation page render
function testOllamaChatConversationPage1ExchangeCalls():
    return [ \
        ['systemFetch', ['getConversation?id=C1']], \
        ['elementModelRender', [testOllamaChatConversationFloatingConv()]], \
        ['documentSetFocus', ['ollama-chat-prompt']], \
        ['documentSetTitle', ['Chat']], \
        ['markdownPrint', ['# Chat','','**Model:** m:1']], \
        ['elementModelRender', [testOllamaChatConversationMessage(0, null, 'chat-bottom', 'u1')]], \
        ['elementModelRender', [testOllamaChatConversationResetDiv]], \
        ['markdownPrint', ['','r1']], \
        ['elementModelRender', [testOllamaChatConversationBottomMenu(0)]], \
        ['elementModelRender', [ \
            [ \
                { \
                    'html': 'div', \
                    'attr': {'style': 'height: 64.000px'} \
                }, \
                { \
                    'html': 'div', \
                    'attr': {'id': "var.vId='C1'&chat-bottom"} \
                } \
            ] \
        ]] \
    ]
endfunction


#
# ollamaChatConversationFloatingElements - no conversation (new chat)
#


function testOllamaChatConversationFloatingNewConv():
    args = argsParse(ollamaChatArguments)
    unittestMockAll({})
    els = ollamaChatConversationFloatingElements(args, null, false)
    unittestMockEnd()
    unittestDeepEqual(els, testOllamaChatConversationFloatingNoConv())
endfunction
unittestRunTest('testOllamaChatConversationFloatingNewConv')


