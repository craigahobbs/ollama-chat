#
# ollamaChatModelsDownloadPage - render branches
#


async function testOllamaChatModelsDownloadPageAll():
    systemGlobalSet('vFilterMonths', 0)
    systemGlobalSet('vFilterCompatible', false)
    args = argsParse(ollamaChatArguments)
    url = 'https://craigahobbs.github.io/ollama-chat/models/models.json'
    model = {'name': 'gemma', 'description': 'A model', 'modified': '2024-01-15', 'downloads': 1500000, 'variants': [ \
        {'id': 'gemma:2b', 'size': '2B', 'parameters': 2000000000}, \
        {'id': 'gemma:70b', 'size': '70B', 'parameters': 70000000000} \
    ]}
    unittestMockAll({'systemFetch': {'getSystemInfo': jsonStringify({'memory': 8000000000}), url: jsonStringify([model])}})
    ollamaChatModelsDownloadPage(args)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['getSystemInfo']], \
        ['systemFetch', [url]], \
        ['documentSetTitle', ['Ollama Chat - Download']], \
        ['markdownPrint', ["[Back](#var.vView='models')",'','# Ollama Chat \- Download']], \
        ['markdownPrint', [ \
            '**Recent:** [1 month](#var.vFilterCompatible=false&var.vFilterMonths=1)' + \
                '\u00a0|\u00a0' + \
                '[3 months](#var.vFilterCompatible=false&var.vFilterMonths=3)' + \
                '\u00a0|\u00a0' + \
                '[6 month](#var.vFilterCompatible=false)' + \
                '\u00a0|\u00a0' + \
                'All', \
            '', \
            '**Show:** [Compatible](#var.vFilterMonths=0)' + '\u00a0|\u00a0' + 'All', \
            '', \
            "**Sort:** [Downloads](#var.vFilterCompatible=false&var.vFilterMonths=0&var.vSort='Downloads')" + \
                '\u00a0|\u00a0' + \
                'Modified' + \
                '\u00a0|\u00a0' + \
                "[Name](#var.vFilterCompatible=false&var.vFilterMonths=0&var.vSort='Name')" \
        ]], \
        ['markdownPrint', [ \
            '## gemma', \
            '', \
            'A model', \
            '', \
            '**Parameters:** 2B, 70B \\', \
            '**Downloads:** 1.5M \\', \
            '**Modified:** 2024-01-15', \
            '', \
            "[Download](#var.vAction='model'&var.vActionID='gemma'&var.vFilterCompatible=false&var.vFilterMonths=0)", \
            '\u00a0|\u00a0' + '[Info](https://ollama.com/library/gemma)' \
        ]] \
    ])
    systemGlobalSet('vFilterMonths', null)
    systemGlobalSet('vFilterCompatible', null)
endfunction
unittestRunTest('testOllamaChatModelsDownloadPageAll')


