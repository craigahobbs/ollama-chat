#
# ollamaChatModelsOnDownloadStop / OnDelete - fetch then re-render the models page
#


async function testOllamaChatModelsOnDownloadStop():
    args = argsParse(ollamaChatArguments)
    unittestMockAll({'systemFetch': {'getModels': jsonStringify({'model': 'm:1', 'models': [], 'downloading': []})}})
    ollamaChatModelsOnDownloadStop(args, 'big:1')
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', [ \
            { \
                'url': 'stopModelDownload', \
                'body': '{"model":"big:1"}' \
            } \
        ]], \
        ['systemFetch', ['getModels']], \
        ['documentSetTitle', ['Ollama Chat - Models']], \
        ['markdownPrint', [ \
            '[Back](#var=)', \
            '', \
            '# Ollama Chat \- Models', \
            '', \
            '**Current Model:** m:1', \
            '', \
            "[Download Models](#var.vView='download')" \
        ]], \
        ['markdownPrint', ['','## Models']], \
        ['markdownPrint', ['','There are no downloaded models.']] \
    ])
endfunction
unittestRunTest('testOllamaChatModelsOnDownloadStop')


