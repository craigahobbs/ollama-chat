include <unittest.bare>
include <unittestMock.bare>

include '../ollamaChat.bare'
include 'testOllamaChatHelpers.bare'


#
# ollamaChatModelsFormatCount - parameter count formatting
#


function testOllamaChatModelsFormatCount():
    unittestEqual(ollamaChatModelsFormatCount(3000), '3.0K')
    unittestEqual(ollamaChatModelsFormatCount(500), '0.5K')
    unittestEqual(ollamaChatModelsFormatCount(3000000), '3.0M')
    unittestEqual(ollamaChatModelsFormatCount(1500000), '1.5M')
    unittestEqual(ollamaChatModelsFormatCount(7000000000), '7.0B')
endfunction
unittestRunTest('testOllamaChatModelsFormatCount')


#
# ollamaChatModelsFormatSize - byte size formatting
#


function testOllamaChatModelsFormatSize():
    unittestEqual(ollamaChatModelsFormatSize(1800), '1.8KB')
    unittestEqual(ollamaChatModelsFormatSize(1800000), '1.7MB')
    unittestEqual(ollamaChatModelsFormatSize(4100000000), '3.8GB')
endfunction
unittestRunTest('testOllamaChatModelsFormatSize')


#
# ollamaChatModelsModelURL - Ollama library URL
#


function testOllamaChatModelsModelURL():
    unittestEqual(ollamaChatModelsModelURL('llm'), 'https://ollama.com/library/llm')
    unittestEqual(ollamaChatModelsModelURL('llama3.2'), 'https://ollama.com/library/llama3.2')
endfunction
unittestRunTest('testOllamaChatModelsModelURL')


#
# ollamaChatModelsFilterLink - filter toggle link
#


function testOllamaChatModelsFilterLink():
    # Current selection - rendered as plain (escaped) text
    unittestEqual(ollamaChatModelsFilterLink('All', 0, 'filterMonths', 0), 'All')

    # Not selected - rendered as a navigation link
    unittestEqual(ollamaChatModelsFilterLink('1 month', 1, 'filterMonths', 6), '[1 month](#var.vFilterMonths=1)')
endfunction
unittestRunTest('testOllamaChatModelsFilterLink')


#
# ollamaChatModelsSort - the model sort comparator
#


function testOllamaChatModelsSort():
    less = {'name': 'aaa', 'downloads': 100, 'modified': '2023-01-01'}
    more = {'name': 'bbb', 'downloads': 200, 'modified': '2023-02-01'}

    # Downloads - higher downloads sorts first
    unittestEqual(ollamaChatModelsSort('Downloads', less, more), 1)
    unittestEqual(ollamaChatModelsSort('Downloads', more, less), -1)

    # Downloads tie - fall back to modified (newer first)
    sameDownloadsOld = {'name': 'aaa', 'downloads': 100, 'modified': '2023-01-01'}
    sameDownloadsNew = {'name': 'bbb', 'downloads': 100, 'modified': '2023-02-01'}
    unittestEqual(ollamaChatModelsSort('Downloads', sameDownloadsOld, sameDownloadsNew), 1)

    # Downloads and modified tie - fall back to name (ascending)
    tieA = {'name': 'aaa', 'downloads': 100, 'modified': '2023-01-01'}
    tieB = {'name': 'bbb', 'downloads': 100, 'modified': '2023-01-01'}
    unittestEqual(ollamaChatModelsSort('Downloads', tieA, tieB), -1)

    # Modified - newer sorts first
    unittestEqual(ollamaChatModelsSort('Modified', less, more), 1)

    # Modified tie - fall back to downloads
    unittestEqual(ollamaChatModelsSort('Modified', tieA, more), 1)

    # Name - ascending
    unittestEqual(ollamaChatModelsSort('Name', less, more), -1)

    # All equal - zero
    unittestEqual(ollamaChatModelsSort('Name', tieA, sameDownloadsOld), 0)
endfunction
unittestRunTest('testOllamaChatModelsSort')


#
# ollamaChatModelsOnModelSelect
#


async function testOllamaChatModelsOnModelSelect():
    unittestMockAll({})
    ollamaChatModelsOnModelSelect('m:1')
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', [ \
            { \
                'url': 'setModel', \
                'body': '{"model":"m:1"}' \
            } \
        ]], \
        ['windowSetLocation', ['#var=']] \
    ])
endfunction
unittestRunTest('testOllamaChatModelsOnModelSelect')


